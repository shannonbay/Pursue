<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_scrollFlags="scroll|enterAlways">

            <!-- Header Section -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/header_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@color/surface">

                <!-- Group Icon Container (80dp circular) -->
                <FrameLayout
                    android:id="@+id/group_icon_container"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    
                    <!-- Group Icon Image (shown when has_icon = true) -->
                    <ImageView
                        android:id="@+id/group_icon_image"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_background"
                        android:visibility="gone"
                        tools:visibility="visible" />
                    
                    <!-- Group Icon Emoji (shown when has_icon = false and icon_emoji exists) -->
                    <TextView
                        android:id="@+id/group_icon_emoji"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:textSize="48sp"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:visibility="gone"
                        tools:text="🏃"
                        tools:visibility="visible" />
                    
                    <!-- Group Icon First Letter (shown when no icon and no emoji) -->
                    <TextView
                        android:id="@+id/group_icon_letter"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/circle_background"
                        android:textColor="@color/on_primary"
                        android:visibility="gone"
                        tools:text="M"
                        tools:visibility="visible" />
                    
                </FrameLayout>

                <!-- Subtitle: Members, Visibility, and Goals -->
                <LinearLayout
                    android:id="@+id/subtitle_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintStart_toEndOf="@id/group_icon_container"
                    app:layout_constraintTop_toTopOf="@id/group_icon_container"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/subtitle_members_goals"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/on_surface_variant"
                        tools:text="8 members" />

                    <TextView
                        android:id="@+id/visibility_divider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" · "
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/on_surface_variant"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <ImageView
                        android:id="@+id/icon_visibility"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="2dp"
                        android:visibility="gone"
                        app:tint="@color/on_surface_variant"
                        tools:src="@drawable/ic_visibility"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/text_visibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/on_surface_variant"
                        android:visibility="gone"
                        tools:text="public"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/goals_divider"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" · "
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/on_surface_variant" />

                    <TextView
                        android:id="@+id/text_goals_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/on_surface_variant"
                        tools:text="5 active goals" />

                </LinearLayout>

                <!-- Created By -->
                <TextView
                    android:id="@+id/created_by"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/on_surface_variant"
                    app:layout_constraintStart_toStartOf="@id/subtitle_container"
                    app:layout_constraintTop_toBottomOf="@id/subtitle_container"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:text="Created by Shannon Thompson" />

                <!-- Heat Section (below created_by) -->
                <LinearLayout
                    android:id="@+id/heat_section"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@id/subtitle_container"
                    app:layout_constraintTop_toBottomOf="@id/created_by"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:visibility="visible">

                    <TextView
                        android:id="@+id/heat_tier_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        tools:text="Blaze" />

                    <TextView
                        android:id="@+id/heat_score_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/on_surface_variant"
                        tools:text="· Score: 72" />

                    <ImageView
                        android:id="@+id/heat_icon_detail"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        tools:src="@drawable/flame5" />

                </LinearLayout>

                <TextView
                    android:id="@+id/heat_details"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/on_surface_variant"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="@id/heat_section"
                    app:layout_constraintTop_toBottomOf="@id/heat_section"
                    app:layout_constraintEnd_toEndOf="parent"
                    tools:visibility="visible"
                    tools:text="5-day streak · Yesterday: 92% (baseline: 80%)" />

                <!-- Communication Link (members only, hidden when not provisioned) -->
                <TextView
                    android:id="@+id/comm_link_row"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="@color/primary"
                    android:drawablePadding="4dp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintStart_toStartOf="@id/subtitle_container"
                    app:layout_constraintTop_toBottomOf="@id/heat_details"
                    tools:text="Join the Discord group →"
                    tools:visibility="visible" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/challenge_header_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@color/surface"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/challenge_header_day_progress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/on_surface_variant"
                    tools:text="Day 8/30 · 22 days left" />

                <ProgressBar
                    android:id="@+id/challenge_header_progress_bar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:layout_marginTop="8dp"
                    android:max="100"
                    android:progress="25"
                    android:progressTint="@color/primary"
                    android:progressBackgroundTint="@color/surface_variant" />

            </LinearLayout>

            <!-- Unified action button row (always visible for all groups) -->
            <LinearLayout
                android:id="@+id/group_action_buttons_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:background="@color/surface">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/challenge_share_button"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:text="@string/challenge_share_button"
                    android:visibility="gone"
                    app:icon="@android:drawable/ic_menu_share" />

                <ImageButton
                    android:id="@+id/challenge_go_live_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:src="@drawable/ic_videocam"
                    android:contentDescription="@string/focus_session_go_live"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/primary"
                    android:padding="0dp"
                    android:scaleType="fitCenter" />

                <ImageButton
                    android:id="@+id/challenge_schedule_button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_calendar"
                    android:contentDescription="@string/focus_session_schedule"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/primary"
                    android:padding="0dp"
                    android:scaleType="fitCenter" />

            </LinearLayout>

            <app.getpursue.ui.views.DailyPulseWidget
                android:id="@+id/daily_pulse_widget"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Focus Session Card (3 states: no-session / active / upcoming-slot) -->
            <LinearLayout
                android:id="@+id/focus_session_card_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <!-- State 2: Active session in progress -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/focus_card_active"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/surface_variant">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <!-- LIVE indicator row -->
                        <LinearLayout
                            android:id="@+id/focus_card_live_row"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <View
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:background="@drawable/bg_dot_filled"
                                android:backgroundTint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="@string/focus_card_live"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/primary"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/focus_card_active_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/focus_card_active_title"
                            android:textAppearance="?attr/textAppearanceTitleSmall"
                            android:textColor="@color/on_surface" />

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/focus_card_participant_avatars"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical" />

                        </HorizontalScrollView>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/focus_card_participant_count"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/on_surface_variant" />

                            <TextView
                                android:id="@+id/focus_card_remaining_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_join_session"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="8dp"
                            android:text="@string/focus_session_join"
                            android:textColor="@color/on_primary"
                            app:backgroundTint="@color/primary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- State 3: Upcoming slot -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/focus_card_slot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/focus_card_slot_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceTitleSmall"
                                android:textColor="@color/on_surface" />

                            <TextView
                                android:id="@+id/focus_card_slot_duration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/on_surface_variant" />

                            <TextView
                                android:id="@+id/focus_card_slot_starts_in"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/on_surface_variant" />

                            <TextView
                                android:id="@+id/focus_card_slot_note"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:visibility="gone"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/on_surface_variant"
                                android:textStyle="italic" />

                            <TextView
                                android:id="@+id/focus_card_slot_rsvp_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/on_surface_variant" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_rsvp_slot"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/focus_session_rsvp_im_in"
                            android:textColor="@color/on_primary"
                            app:backgroundTint="@color/primary" />

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

        <!-- Tabs (sticky — no scroll flags) -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/primary">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_goals" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_members" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_activity" />

        </com.google.android.material.tabs.TabLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ViewPager2 for Tab Content -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- Floating Action Button (context-aware) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_action"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="@string/fab_log_progress"
        app:backgroundTint="@color/primary"
        app:srcCompat="@android:drawable/ic_input_add"
        app:tint="@color/on_primary"
        app:maxImageSize="34dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
