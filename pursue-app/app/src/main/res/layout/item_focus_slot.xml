<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Color dot indicator -->
    <View
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="#1976D2"
        android:layout_marginEnd="12dp" />

    <!-- Slot info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Time -->
        <TextView
            android:id="@+id/slot_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/on_surface"
            tools:text="3:00 PM" />

        <!-- Group name + duration -->
        <TextView
            android:id="@+id/slot_group_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/on_surface_variant"
            tools:text="Morning Writers · 45 min" />

        <!-- Note -->
        <TextView
            android:id="@+id/slot_note"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/on_surface_variant"
            android:visibility="gone"
            tools:text="Writing sprint 🖊️" />

        <!-- RSVP count -->
        <TextView
            android:id="@+id/slot_rsvp_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/on_surface_variant"
            tools:text="Jordan + 2 going" />

    </LinearLayout>

    <!-- RSVP toggle button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_slot_rsvp"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="@string/focus_slots_im_in"
        android:textColor="@color/on_primary"
        app:backgroundTint="@color/primary"
        android:layout_marginStart="8dp" />

</LinearLayout>
